# GitHub OAuth cloud sync
#
# Create a GitHub OAuth App at:
# https://github.com/settings/developers
#
# Homepage URL:
# https://your-app.vercel.app
#
# Authorization callback URL:
# https://your-app.vercel.app/api/auth
#
# Vercel/server-side environment variables:
# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# APP_ORIGIN=https://your-app.vercel.app
#
# APP_ORIGIN is optional on Vercel because /api/auth can infer the current host.
# Set it only when you need to force a custom public origin.
#
# VITE_GITHUB_CLIENT_ID is no longer required. OAuth starts from /api/auth so
# the browser does not need a GitHub client id baked into the frontend bundle.
