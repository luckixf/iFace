[{"id":"highway-chapters-10-2-5a0743f0-q001","module":"公路工程管理与实务 · 10.2施工进度控制","difficulty":1,"type":"single","question":"“前锋线比较法”主要适用于（ ）的进度计划检查。","answer":"## 正确答案\nC\n\n## 解析\n前锋线比较法是通过绘制某检查时刻到工程项目实际进度前锋线，进行工程实际进度与计划进度比较的方法，它主要适用于时标网络计划。","tags":["公路工程管理与实务","单选题"],"source":"章节精讲","options":[{"key":"A","text":"时标网络图"},{"key":"B","text":"“S”型曲缝"},{"key":"C","text":"横道图"},{"key":"D","text":"“香蕉”型曲线"}],"correctAnswers":["C"],"questionImages":["/question-assets/construction/highway/chapters/highway-chapters-10-2-5a0743f0/q001-1.webp"]}]