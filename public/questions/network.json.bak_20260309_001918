    "answer": "## 长轮询（Long Polling）\n\n### 普通轮询\n```js\n// 客户端每隔一段时间发送请求\nsetInterval(async () => {\n  const res = await fetch('/api/messages');\n  const data = await res.json();\n  updateMessages(data);\n}, 1000);\n\n// 缺点：浪费带宽，即使没有新消息也发请求\n```\n\n### 长轮询\n```js\n// 客户端发起请求，服务器挂起直到有新数据或超时\nasync function longPoll() {\n  try {\n    const res = await fetch('/api/messages/poll', {\n      signal: AbortSignal.timeout(30000) // 30s 超时\n    });\n    const data = await res.json();\n    handleNewMessage(data);\n  } catch (e) {\n    // 超时或错误\n  } finally {\n    longPoll(); // 立即发起下一次请求\n  }\n}\n\nlongPoll();\n```\n\n```js\n// 服务端（Node.js）\nconst clients = new Map();\n\napp.get('/api/messages/poll', (req, res) => {\n  const clientId = req.query.clientId;\n  const timeout = setTimeout(() => {\n    clients.delete(clientId);\n    res.json({ messages: [] }); // 超时返回空\n  }, 25000);\n\n  clients.set(clientId, { res, timeout });\n});\n\n// 有新消息时推送\nfunction broadcast(message) {\n  clients.forEach(({ res, timeout }, clientId) => {\n    clearTimeout(timeout);\n    clients.delete(clientId);\n    res.json({ messages: [message] });\n  });\n}\n```\n\n### 三种方案对比\n| | 短轮询 | 长轮询 | WebSocket |\n|--|--------|--------|----------|\n| 实时性 | 差 | 较好 | 最好 |\n| 服务器压力 | 大 | 中 | 小 |\n| 实现复杂度 | 低 | 中 | 高 |\n| HTTP 兼容 | ✅ | ✅ | 需升级 |\n| 适用场景 | 低频更新 | 中频更新 | 高频双向 |",
