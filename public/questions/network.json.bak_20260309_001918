    "answer": "## 请求取消和超时控制\n\n### AbortController（取消请求）\n```js\nconst controller = new AbortController();\nconst { signal } = controller;\n\n// 发起可取消的请求\nasync function fetchWithCancel(url) {\n  try {\n    const res = await fetch(url, { signal });\n    return await res.json();\n  } catch (e) {\n    if (e.name === 'AbortError') {\n      console.log('请求被取消');\n    } else {\n      throw e;\n    }\n  }\n}\n\n// 取消请求\ncontroller.abort('用户取消');\n```\n\n### 超时控制\n```js\n// 方法1：AbortSignal.timeout（现代浏览器）\ntry {\n  const res = await fetch('/api/data', {\n    signal: AbortSignal.timeout(5000) // 5秒超时\n  });\n} catch (e) {\n  if (e.name === 'TimeoutError') {\n    console.log('请求超时');\n  }\n}\n\n// 方法2：Promise.race\nfunction fetchWithTimeout(url, timeout = 5000) {\n  const controller = new AbortController();\n  const timeoutId = setTimeout(() => controller.abort(), timeout);\n\n  return fetch(url, { signal: controller.signal })\n    .finally(() => clearTimeout(timeoutId));\n}\n\n// 方法3：同时处理取消和超时\nfunction fetchEnhanced(url, options = {}) {\n  const { timeout = 10000, signal: outerSignal } = options;\n  const controller = new AbortController();\n  const timeoutId = setTimeout(() => controller.abort(), timeout);\n\n  // 合并外部信号和超时信号\n  outerSignal?.addEventListener('abort', () => controller.abort());\n\n  return fetch(url, { ...options, signal: controller.signal })\n    .finally(() => clearTimeout(timeoutId));\n}\n```\n\n### React 中的请求取消\n```jsx\nuseEffect(() => {\n  const controller = new AbortController();\n\n  async function loadData() {\n    try {\n      const res = await fetch('/api/user', {\n        signal: controller.signal\n      });\n      const data = await res.json();\n      setUser(data);\n    } catch (e) {\n      if (e.name !== 'AbortError') {\n        setError(e.message);\n      }\n    }\n  }\n\n  loadData();\n\n  return () => controller.abort(); // 组件卸载时取消\n}, [userId]);\n```\n\n### Axios 取消\n```js\n// Axios CancelToken（旧）\nconst cancelToken = axios.CancelToken;\nconst source = cancelToken.source();\n\naxios.get('/api/data', { cancelToken: source.token });\nsource.cancel('用户取消');\n\n// Axios AbortController（新，推荐）\nconst controller = new AbortController();\naxios.get('/api/data', { signal: controller.signal });\ncontroller.abort();\n```",
